<?xml version="1.0"?>
<robot name="trash_bot">

  <!-- Links -->
  <link name="base_link">
    <inertial>
      <mass value="5.0" />
      <inertia ixx="0.333333" ixy="0" ixz="0" iyy="0.333333" iyz="0" izz="0.333333" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://trash_bot/meshes/base_link.stl" />
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://trash_bot/meshes/base_link.stl" />
      </geometry>
    </collision>
  </link>

  <link name="body_link">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.116667" ixy="0" ixz="0" iyy="0.116667" iyz="0" izz="0.116667" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://trash_bot/meshes/body_link.stl" />
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://trash_bot/meshes/body_link.stl" />
      </geometry>
    </collision>
  </link>

  <link name="rear_right_wheel">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.003333" ixy="0" ixz="0" iyy="0.003333" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </collision>
  </link>

  <link name="rear_left_wheel">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.003333" ixy="0" ixz="0" iyy="0.003333" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </collision>
  </link>

  <link name="gpu_lidar">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.003333" ixy="0" ixz="0" iyy="0.003333" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.05" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </collision>
  </link>

  <link name="head_lidar">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.000521" ixy="0" ixz="0" iyy="0.000521" iyz="0" izz="0.000833" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.1 0.1" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.05 0.1 0.1" />
      </geometry>
    </collision>
  </link>

  <link name="front_right_wheel">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.003333" ixy="0" ixz="0" iyy="0.003333" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </collision>
  </link>

  <link name="front_left_wheel">
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.003333" ixy="0" ixz="0" iyy="0.003333" iyz="0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.1" length="0.1" />
      </geometry>
    </collision>
  </link>

  <!-- Joints -->
  <joint name="cylinder_joint" type="revolute">
    <origin xyz="0 -0.45 1.6" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="body_link" />
    <axis xyz="1 0 0"/>
    <limit effort="1000" velocity="10" lower="-3.14" upper="3.14" />
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <origin xyz="-0.45 -0.55798 -0.1" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="rear_right_wheel" />
    <axis xyz="0 0 1" />
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <origin xyz="-0.45 0.55 -0.1" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="rear_left_wheel" />
    <axis xyz="0 0 1" />
  </joint>

  <joint name="gpu_lidar_joint" type="fixed">
    <origin xyz="0 0 0.1" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="gpu_lidar" />
  </joint>

  <joint name="head_lidar_joint" type="fixed">
    <origin xyz="0 0.75 -0.05" rpy="0 1.5708 1.5708" />
    <parent link="body_link" />
    <child link="head_lidar" />
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.45 -0.55 -0.1" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="front_right_wheel" />
    <axis xyz="0 0 1" />
  </joint>

  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.45 0.55 -0.1" rpy="-1.5708 0 0" />
    <parent link="base_link" />
    <child link="front_left_wheel" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- ───── Gazebo Fortress ───── -->

  <gazebo reference="front_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="rear_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>0</mu><mu2>0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>0</mu><mu2>0</mu2></ode>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <!-- ───── Diff drive plugin ───── -->

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>1.1</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>10</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_acceleration>1.0</max_linear_acceleration>
    </plugin>
  </gazebo>

  <!-- ───── LiDAR sensor (2D) ───── -->

  <gazebo reference="gpu_lidar">
    <sensor name="laser" type="gpu_lidar">
      <gz_frame_id>gpu_lidar</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.8</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ───── LiDAR sensor (2D) ───── -->

  <gazebo reference="head_lidar">
    <sensor name="laser" type="gpu_lidar">
      <gz_frame_id>head_lidar</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan1</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-0.2</min_angle>
            <max_angle>0.2</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ───── Gazebo sim ROS2 Control Plugin ───── -->

  <gazebo>
    <plugin filename="ign_ros2_control-system"
        name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>
        /home/minj/ros2_ws/install/trash_bot/share/trash_bot/config/trashbot_controller.yaml
      </parameters>
      <hold_joints>false</hold_joints>
    </plugin>
  </gazebo>

  <!-- ───── ros2_control ───── -->

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin>
    </hardware>
    <joint name="cylinder_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>